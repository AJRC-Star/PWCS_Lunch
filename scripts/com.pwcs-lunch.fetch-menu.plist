<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.pwcs-lunch.fetch-menu</string>

    <key>ProgramArguments</key>
    <array>
        <string>/bin/bash</string>
        <string>/Users/ajstaranowicz/PWCS_Lunch/scripts/local-fetch.sh</string>
    </array>

    <!-- Run every Saturday at 06:00 local time (= 10:00 UTC during EDT) -->
    <key>StartCalendarInterval</key>
    <dict>
        <key>Weekday</key>
        <integer>6</integer>
        <key>Hour</key>
        <integer>6</integer>
        <key>Minute</key>
        <integer>0</integer>
    </dict>

    <key>StandardOutPath</key>
    <string>/Users/ajstaranowicz/PWCS_Lunch/logs/fetch.log</string>
    <key>StandardErrorPath</key>
    <string>/Users/ajstaranowicz/PWCS_Lunch/logs/fetch-error.log</string>

    <!-- Run missed jobs when the Mac wakes up after the scheduled time -->
    <key>RunAtLoad</key>
    <false/>
</dict>
</plist>
